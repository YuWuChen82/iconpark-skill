#!/bin/bash
# scripts/git-hooks/pre-push
#
# Git pre-push hook: 自动 bump 版本号 before push。
#
# 用法: bash scripts/install-git-hooks.sh
#
# 跳过规则:
#   - 参数含 `--no-bump`
#   - 环境变量 GIT_PUSH_NO_BUMP=1
#   - 上一次 commit 已是 `chore: bump v...`
#   - VERSION / SKILL.md / package.json 有未提交改动
#
# 装完后: ls -la "$(git rev-parse --git-dir)/hooks/pre-push"

for arg in "$@"; do
  if [ "$arg" = "--no-bump" ]; then
    exit 0
  fi
done

if [ "$GIT_PUSH_NO_BUMP" = "1" ]; then
  exit 0
fi

# Resolve repo root: 此 hook 可能从 scripts/git-hooks/ 被 cp 到 .git/hooks/
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

# 健壮性检查: 不是仓库根目录 / 缺脚本 → 静默退出
if [ ! -f "$REPO_ROOT/scripts/auto-bump-version.js" ]; then
  exit 0
fi

cd "$REPO_ROOT" || exit 0
node scripts/auto-bump-version.js --skip-if-clean
exit 0
